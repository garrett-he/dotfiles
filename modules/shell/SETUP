setup() {
    local ostype

    ostype=$(dotfiles_ostype)

    for shell in zsh bash; do
        dotfiles_backup_files "$HOME/.${shell}rc"
        dotfiles_append_shell_profile "source $MODULE_DIR/${shell}_profile" "$shell"
    done

    dotfiles_append_shell_profile "source $MODULE_DIR/profile"

    if [[ -f "$MODULE_DIR/${ostype}_profile" ]]; then
        dotfiles_append_shell_profile "source $MODULE_DIR/${ostype}_profile"
    fi
}
